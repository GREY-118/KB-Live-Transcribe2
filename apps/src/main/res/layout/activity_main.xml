<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="@string/tagline"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Mic permission card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_menu_item_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/textMicTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/perm_mic_title"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"
                android:text="@string/perm_mic_desc"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnGrantMic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/perm_mic_grant" />
        </LinearLayout>

        <!-- Overlay permission card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_menu_item_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/textOverlayTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/perm_overlay_title"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"
                android:text="@string/perm_overlay_desc"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnGrantOverlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/perm_overlay_grant" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/language_label"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerLanguage"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_menu_item_card" />

        <Button
            android:id="@+id/btnToggleService"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/brand_primary"
            android:text="@string/start_captioning"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
